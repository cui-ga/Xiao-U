  "dialogue": {
    "enabled": true,
    "max_history_turns": 5,
    "session_timeout_seconds": 1800,
    "enable_coreference_resolution": true,
    "enable_query_rewrite": true,
    "core_entity_types": ["DISEASE", "疾病", "SYMPTOM", "症状", "DRUG", "药品"],
    "default_session_id": "default_user"
  }
