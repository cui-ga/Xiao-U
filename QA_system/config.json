{
  "neo4j_uri": "bolt://127.0.0.1:7687",
  "neo4j_user": "neo4j",
  "neo4j_password": "12345678",
  "neo4j_database": "neo4j",
  "enable_cache": true,
  "enable_debug": true,
  "timeout": 30,
  "max_entities": 10,
  "enable_fallback": true,
  "log_level": "INFO",
